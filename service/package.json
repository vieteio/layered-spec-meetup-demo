{
  "name": "construction-drawing-estimation-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,ws -c blue,green \"next dev\" \"tsx src/server/wsStandalone.ts\"",
    "build": "next build",
    "start": "tsx server.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
